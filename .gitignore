#============================================================================#
# Angular / Ionic / Capacitor Monorepo – .gitignore
#============================================================================#

#-------------------------------------------------------------
# Node.js / npm
#-------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

#-------------------------------------------------------------
# Build outputs
#-------------------------------------------------------------
dist/
out-tsc/
*.js.map
*.js
*.d.ts
!(.d.ts)

#-------------------------------------------------------------
# Angular specific
#-------------------------------------------------------------
.angular/
*.ngsummary.json
*.ngfactory.ts
*.ngfactory.js
*.ngsummary.js

#-------------------------------------------------------------
# Ionic / Capacitor
#-------------------------------------------------------------
www/
android/
ios/
.capacitor/
capacitor.config.json
capacitor.config.ts
*.apk
*.aab
*.ipa

#-------------------------------------------------------------
# Environment files (local overrides)
#-------------------------------------------------------------
src/environments/environment.local.ts
src/environments/environment.prod.local.ts
*.local.ts

#-------------------------------------------------------------
# IDE / Editor
#-------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.iml
.vscode/settings.json
.vscode/launch.json

#-------------------------------------------------------------
# OS / System
#-------------------------------------------------------------
.DS_Store
Thumbs.db
*.tmp
*.log

#-------------------------------------------------------------
# Testing / Coverage
#-------------------------------------------------------------
coverage/
.nyc_output/
*.test.ts
*.spec.ts
*.spec.js

# Verixora security tests are source code and must remain version controlled.
!projects/mobile-app/src/app/core/**/*.spec.ts
!projects/web-portal/src/app/core/**/*.spec.ts

#-------------------------------------------------------------
# Temporary files / cache
#-------------------------------------------------------------
*.cache
*.tmp
*.temp
*.swp

#-------------------------------------------------------------
# Secrets / Keys
#-------------------------------------------------------------
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
*.jks
*.keystore
google-services.json
GoogleService-Info.plist

#-------------------------------------------------------------
# Capacitor plugins (generated)
#-------------------------------------------------------------
plugins/
capacitor-cordova-android-plugins/
capacitor-cordova-ios-plugins/

#-------------------------------------------------------------
# Firebase / Cloud
#-------------------------------------------------------------
firebase-debug.log
.firebase/
.firebase.json

#-------------------------------------------------------------
# Misc
#-------------------------------------------------------------
*.orig
*.rej
*.patch
